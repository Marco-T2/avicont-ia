// prisma/schema.prisma
// Define your database models

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String   @id @default(cuid())
  clerkOrgId  String   @unique
  name        String
  slug        String   @unique
  createdAt   DateTime @db.Timestamptz(3) @default(now())
  members        OrganizationMember[]
  documents      Document[]
  farms          Farm[]
  chickenLots    ChickenLot[]
  expenses       Expense[]
  mortalityLogs  MortalityLog[]
  accounts        Account[]
  journalEntries  JournalEntry[]
  fiscalPeriods   FiscalPeriod[]
  fiscalYears     FiscalYear[]
  voucherTypes    VoucherTypeCfg[]
  accountBalances AccountBalance[]
  contacts        Contact[]
  receivables     AccountsReceivable[]
  payables        AccountsPayable[]
  settings        OrgSettings?
  dispatches         Dispatch[]
  payments           Payment[]
  purchases          Purchase[]
  sales              Sale[]
  productTypes          ProductType[]
  operationalDocTypes   OperationalDocType[]
  auditLogs             AuditLog[]
  ivaPurchaseBooks      IvaPurchaseBook[]
  ivaSalesBooks         IvaSalesBook[]
  customRoles           CustomRole[]
  profile                  OrgProfile?
  documentSignatureConfigs DocumentSignatureConfig[]

  @@map("organizations")
}

model CustomRole {
  id               String   @id @default(cuid())
  organizationId   String
  slug             String
  name             String
  description      String?
  isSystem         Boolean  @default(false)
  permissionsRead  String[]
  permissionsWrite String[]
  canPost          String[]
  createdAt        DateTime @db.Timestamptz(3) @default(now())
  updatedAt        DateTime @db.Timestamptz(3) @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId, isSystem])
  @@map("custom_roles")
}

model OrganizationMember {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  role           String    @default("member")
  deactivatedAt  DateTime? @db.Timestamptz(3)
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  farms          Farm[]

  @@unique([organizationId, userId])
  @@index([organizationId, deactivatedAt])
  @@map("organization_members")
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String
  name        String?
  createdAt   DateTime @db.Timestamptz(3) @default(now())
  memberships    OrganizationMember[]
  documents      Document[]
  expenses       Expense[]       @relation("ExpenseCreator")
  mortalityLogs  MortalityLog[]  @relation("MortalityCreator")
  journalEntries JournalEntry[]  @relation("JournalCreator")
  dispatches     Dispatch[]      @relation("DispatchCreator")
  payments       Payment[]       @relation("PaymentCreator")
  purchases      Purchase[]      @relation("PurchaseCreator")
  sales          Sale[]          @relation("SaleCreator")
  closedPeriods  FiscalPeriod[]  @relation("FiscalPeriodCloser")
  closedFiscalYears  FiscalYear[] @relation("FiscalYearCloser")
  createdFiscalYears FiscalYear[] @relation("FiscalYearCreator")

  @@map("users")
}

model Document {
  id             String        @id @default(cuid())
  name           String
  content        String?
  fileUrl        String?
  fileSize       Int?
  fileType       String?
  aiSummary      String?
  scope          DocumentScope @default(ORGANIZATION)
  organizationId String
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  chunks         DocumentChunk[]

  createdAt      DateTime @db.Timestamptz(3) @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, scope])
  @@map("documents")
}

model DocumentChunk {
  id             String        @id @default(cuid())
  documentId     String
  organizationId String
  scope          DocumentScope
  content        String
  chunkIndex     Int
  sectionPath    String?       @db.VarChar(512)
  embedding      Unsupported("vector(768)")
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([organizationId, scope])
  @@map("document_chunks")
}

model ChatMessage {
  id             String   @id @default(cuid())
  sessionId      String
  organizationId String
  userId         String
  role           String
  content        String
  createdAt      DateTime @db.Timestamptz(3) @default(now())

  @@index([sessionId, createdAt])
  @@index([organizationId, userId])
  @@map("chat_messages")
}

// Hourly bucket counter for the agent rate limiter.
// Per-user limit: counted directly on this row's `count` (one row per
// (org,user,hour)). Per-org limit: SUM(count) across rows matching
// (organizationId, windowStart). Keeping a single non-null `userId` avoids
// the NULL-in-UNIQUE Postgres pitfall (NULLs are treated as DISTINCT).
model AgentRateLimit {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  windowStart    DateTime @db.Timestamptz(3)
  count          Int      @default(0)
  updatedAt      DateTime @db.Timestamptz(3) @updatedAt

  @@unique([organizationId, userId, windowStart])
  @@index([windowStart])
  @@index([organizationId, windowStart])
  @@map("agent_rate_limits")
}

enum LotStatus {
  ACTIVE
  CLOSED
  SOLD
}

enum ExpenseCategory {
  ALIMENTO
  CHALA
  AGUA
  GARRAFAS
  MANTENIMIENTO
  GALPONERO
  MEDICAMENTOS
  VETERINARIO
  OTROS
}

model Farm {
  id             String   @id @default(cuid())
  name           String
  location       String?
  organizationId String
  memberId       String
  createdAt      DateTime @db.Timestamptz(3) @default(now())
  updatedAt      DateTime @db.Timestamptz(3) @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id])
  member         OrganizationMember @relation(fields: [memberId], references: [id])
  lots           ChickenLot[]

  @@index([organizationId])
  @@index([memberId])
  @@map("farms")
}

model ChickenLot {
  id             String    @id @default(cuid())
  name           String
  barnNumber     Int
  initialCount   Int
  startDate      DateTime @db.Timestamptz(3)
  endDate        DateTime? @db.Timestamptz(3)
  status         LotStatus @default(ACTIVE)
  farmId         String
  organizationId String
  createdAt      DateTime  @db.Timestamptz(3) @default(now())
  updatedAt      DateTime  @db.Timestamptz(3) @updatedAt
  farm           Farm         @relation(fields: [farmId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  expenses       Expense[]
  mortalityLogs  MortalityLog[]

  @@index([organizationId])
  @@index([farmId])
  @@map("chicken_lots")
}

model Expense {
  id             String          @id @default(cuid())
  amount         Decimal         @db.Decimal(12, 2)
  category       ExpenseCategory
  description    String?
  date           DateTime @db.Timestamptz(3)
  lotId          String
  organizationId String
  createdById    String
  createdAt      DateTime        @db.Timestamptz(3) @default(now())
  lot            ChickenLot   @relation(fields: [lotId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdBy      User         @relation("ExpenseCreator", fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([lotId])
  @@index([createdById])
  @@map("expenses")
}

model MortalityLog {
  id             String   @id @default(cuid())
  count          Int
  cause          String?
  date           DateTime @db.Timestamptz(3)
  lotId          String
  organizationId String
  createdById    String
  createdAt      DateTime @db.Timestamptz(3) @default(now())
  lot            ChickenLot   @relation(fields: [lotId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdBy      User         @relation("MortalityCreator", fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([lotId])
  @@index([createdById])
  @@map("mortality_logs")
}

enum DocumentScope {
  ORGANIZATION
  ACCOUNTING
  FARM
}

enum AccountType {
  ACTIVO
  PASIVO
  PATRIMONIO
  INGRESO
  GASTO
}

enum AccountSubtype {
  // Activo
  ACTIVO_CORRIENTE
  ACTIVO_NO_CORRIENTE
  // Pasivo
  PASIVO_CORRIENTE
  PASIVO_NO_CORRIENTE
  // Patrimonio
  PATRIMONIO_CAPITAL
  PATRIMONIO_RESULTADOS
  // Ingreso
  INGRESO_OPERATIVO
  INGRESO_NO_OPERATIVO
  // Gasto
  GASTO_OPERATIVO
  GASTO_ADMINISTRATIVO
  GASTO_FINANCIERO
  GASTO_NO_OPERATIVO
}

enum AccountNature {
  DEUDORA   // Activos y Gastos: saldo aumenta con Debe
  ACREEDORA // Pasivos, Patrimonio, Ingresos: saldo aumenta con Haber
}

enum FiscalPeriodStatus {
  OPEN
  CLOSED
}

enum FiscalYearStatus {
  OPEN
  CLOSED
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  LOCKED
  VOIDED
}

enum OperationalDocDirection {
  COBRO
  PAGO
  BOTH
}

model Account {
  id              String         @id @default(cuid())
  code            String
  name            String
  type            AccountType
  nature          AccountNature
  subtype         AccountSubtype? // Subtipo contable NIIF/PCGA; null solo en cuentas raíz (nivel 1)
  parentId        String?
  level           Int
  isDetail        Boolean        @default(false)
  requiresContact Boolean        @default(false)
  description       String?
  isActive          Boolean        @default(true)
  isContraAccount   Boolean        @default(false)
  organizationId  String
  parent          Account?       @relation("AccountTree", fields: [parentId], references: [id])
  children        Account[]      @relation("AccountTree")
  organization    Organization   @relation(fields: [organizationId], references: [id])
  journalLines    JournalLine[]
  balances        AccountBalance[]
  purchaseDetails PurchaseDetail[]
  saleDetails     SaleDetail[]

  @@unique([organizationId, code])
  @@index([parentId])
  @@index([organizationId, subtype])
  @@map("accounts")
}

model JournalEntry {
  id              String             @id @default(cuid())
  number          Int
  referenceNumber Int?               // optional physical document number
  date            DateTime           @db.Timestamptz(3)
  description     String
  status          JournalEntryStatus @default(DRAFT)
  periodId        String
  voucherTypeId   String
  contactId       String?
  sourceType      String?
  sourceId        String?
  aiOriginalText  String?            // texto crudo del usuario cuando sourceType="ai" — inmutable post-creación
  organizationId  String
  createdById     String
  updatedById     String?
  createdAt       DateTime           @db.Timestamptz(3) @default(now())
  updatedAt       DateTime           @db.Timestamptz(3) @updatedAt
  organization    Organization       @relation(fields: [organizationId], references: [id])
  period          FiscalPeriod       @relation(fields: [periodId], references: [id])
  voucherType     VoucherTypeCfg     @relation(fields: [voucherTypeId], references: [id])
  createdBy       User               @relation("JournalCreator", fields: [createdById], references: [id])
  contact         Contact?           @relation(fields: [contactId], references: [id])
  lines           JournalLine[]
  receivables     AccountsReceivable[]
  payables        AccountsPayable[]
  dispatch        Dispatch?
  payment         Payment?
  purchase        Purchase?
  sale            Sale?
  @@unique([organizationId, voucherTypeId, periodId, number])
  @@unique([organizationId, voucherTypeId, referenceNumber])
  @@index([organizationId, periodId])
  @@index([organizationId, status])
  @@index([organizationId, voucherTypeId, referenceNumber])
  @@index([createdById])
  @@map("journal_entries")
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal      @default(0) @db.Decimal(12, 2)
  credit         Decimal      @default(0) @db.Decimal(12, 2)
  description    String?
  contactId      String?
  order          Int          @default(0)
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        Account      @relation(fields: [accountId], references: [id])
  contact        Contact?     @relation(fields: [contactId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_lines")
}

model FiscalPeriod {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  year           Int
  month          Int                // 1..12 — calendar month (CHECK constraint in migration)
  startDate      DateTime           @db.Timestamptz(3)
  endDate        DateTime           @db.Timestamptz(3)
  status         FiscalPeriodStatus @default(OPEN)
  closedAt       DateTime?          @db.Timestamptz(3)
  closedBy       String?
  createdById    String
  // NOTE: no FK to FiscalYear in v1 — the canonical link is logical via
  // (organizationId, year) joined against fiscal_years.@@unique([organizationId, year]).
  // See annual-close design rev 2 §2 and proposal §11 OUT.
  createdAt      DateTime           @db.Timestamptz(3) @default(now())
  updatedAt      DateTime           @db.Timestamptz(3) @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id])
  closedByUser   User?              @relation("FiscalPeriodCloser", fields: [closedBy], references: [id])
  journalEntries JournalEntry[]
  balances       AccountBalance[]
  dispatches     Dispatch[]
  payments         Payment[]
  purchases        Purchase[]
  sales            Sale[]
  ivaPurchaseBooks IvaPurchaseBook[]
  ivaSalesBooks    IvaSalesBook[]

  @@unique([organizationId, year, month])
  @@index([organizationId, status])
  @@map("fiscal_periods")
}

model FiscalYear {
  id              String           @id @default(cuid())
  organizationId  String
  year            Int              // CHECK 1900..2100 via migration
  status          FiscalYearStatus @default(OPEN)
  closedAt        DateTime?        @db.Timestamptz(3)
  closedBy        String?
  justification   String?
  createdById     String
  createdAt       DateTime         @db.Timestamptz(3) @default(now())
  updatedAt       DateTime         @db.Timestamptz(3) @updatedAt
  organization    Organization     @relation(fields: [organizationId], references: [id])
  closedByUser    User?            @relation("FiscalYearCloser", fields: [closedBy], references: [id])
  createdByUser   User             @relation("FiscalYearCreator", fields: [createdById], references: [id])
  // NOTE: no inverse `fiscalPeriods FiscalPeriod[]` in v1 — link is logical
  // via (organizationId, year). See annual-close design rev 2 §2.

  @@unique([organizationId, year])
  @@index([organizationId, status])
  @@map("fiscal_years")
}

model VoucherTypeCfg {
  id             String          @id @default(cuid())
  organizationId String
  code           String
  prefix         String
  name           String
  description    String?
  isActive       Boolean         @default(true)
  isAdjustment   Boolean         @default(false)
  organization   Organization    @relation(fields: [organizationId], references: [id])
  journalEntries JournalEntry[]

  @@unique([organizationId, code])
  @@map("voucher_types")
}

model AccountBalance {
  id             String       @id @default(cuid())
  organizationId String
  accountId      String
  periodId       String
  debitTotal     Decimal      @default(0) @db.Decimal(12, 2)
  creditTotal    Decimal      @default(0) @db.Decimal(12, 2)
  balance        Decimal      @default(0) @db.Decimal(12, 2)
  organization   Organization @relation(fields: [organizationId], references: [id])
  account        Account      @relation(fields: [accountId], references: [id])
  period         FiscalPeriod @relation(fields: [periodId], references: [id])

  @@unique([accountId, periodId])
  @@index([organizationId, periodId])
  @@map("account_balances")
}

// --- Contacts, Receivables, Payables ---

enum ContactType {
  CLIENTE
  PROVEEDOR
  SOCIO
  TRANSPORTISTA
  OTRO
}

enum ReceivableStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED // kept for PostgreSQL compatibility — application code uses VOIDED
  VOIDED
  OVERDUE
}

enum PayableStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED // kept for PostgreSQL compatibility — application code uses VOIDED
  VOIDED
  OVERDUE
}

enum SaleStatus {
  DRAFT
  POSTED
  LOCKED
  VOIDED
}

enum PurchaseType {
  FLETE
  POLLO_FAENADO
  COMPRA_GENERAL
  SERVICIO
}

enum PurchaseStatus {
  DRAFT
  POSTED
  LOCKED
  VOIDED
}

enum DispatchType {
  NOTA_DESPACHO
  BOLETA_CERRADA
}

enum DispatchStatus {
  DRAFT
  POSTED
  LOCKED
  VOIDED
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  CHEQUE
  DEPOSITO
}

enum IvaBookStatus {
  ACTIVE
  VOIDED
}

enum IvaSalesEstadoSIN {
  A
  V
  C
  L
}

enum PaymentStatus {
  DRAFT
  POSTED
  LOCKED
  VOIDED
}

model Contact {
  id               String      @id @default(cuid())
  organizationId   String
  type             ContactType
  name             String
  nit              String?
  email            String?
  phone            String?
  address          String?
  paymentTermsDays Int         @default(30)
  creditLimit      Decimal?    @db.Decimal(12, 2)
  isActive         Boolean     @default(true)
  createdAt        DateTime    @db.Timestamptz(3) @default(now())
  updatedAt        DateTime    @db.Timestamptz(3) @updatedAt
  organization     Organization         @relation(fields: [organizationId], references: [id])
  journalEntries   JournalEntry[]
  journalLines     JournalLine[]
  receivables      AccountsReceivable[]
  payables         AccountsPayable[]
  dispatches       Dispatch[]
  payments         Payment[]
  purchases        Purchase[]
  sales            Sale[]

  @@index([organizationId, type])
  @@index([organizationId, isActive])
  @@index([organizationId, nit])
  @@map("contacts")
}

model AccountsReceivable {
  id             String           @id @default(cuid())
  organizationId String
  contactId      String
  description    String
  amount         Decimal          @db.Decimal(12, 2)
  paid           Decimal          @default(0) @db.Decimal(12, 2)
  balance        Decimal          @db.Decimal(12, 2)
  dueDate        DateTime         @db.Timestamptz(3)
  status         ReceivableStatus @default(PENDING)
  sourceType     String?
  sourceId       String?
  journalEntryId String?
  notes          String?
  createdAt      DateTime         @db.Timestamptz(3) @default(now())
  updatedAt      DateTime         @db.Timestamptz(3) @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id])
  contact        Contact       @relation(fields: [contactId], references: [id])
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  dispatch       Dispatch?
  sale           Sale?
  allocations    PaymentAllocation[]

  @@index([organizationId, contactId])
  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@map("accounts_receivable")
}

model AccountsPayable {
  id             String        @id @default(cuid())
  organizationId String
  contactId      String
  description    String
  amount         Decimal       @db.Decimal(12, 2)
  paid           Decimal       @default(0) @db.Decimal(12, 2)
  balance        Decimal       @db.Decimal(12, 2)
  dueDate        DateTime      @db.Timestamptz(3)
  status         PayableStatus @default(PENDING)
  sourceType     String?
  sourceId       String?
  journalEntryId String?
  notes          String?
  createdAt      DateTime      @db.Timestamptz(3) @default(now())
  updatedAt      DateTime      @db.Timestamptz(3) @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id])
  contact        Contact       @relation(fields: [contactId], references: [id])
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  purchase       Purchase?
  allocations    PaymentAllocation[]

  @@index([organizationId, contactId])
  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@map("accounts_payable")
}

// --- OrgSettings, Dispatch, Payment ---

model OrgSettings {
  id                     String       @id @default(cuid())
  organizationId         String       @unique
  cajaGeneralAccountCode String       @default("1.1.1.1")
  bancoAccountCode       String       @default("1.1.3.1")
  cxcAccountCode         String       @default("1.1.4.1")
  cxpAccountCode         String       @default("2.1.1.1")
  roundingThreshold      Decimal      @default(0.7) @db.Decimal(3, 2)
  cashParentCode         String       @default("1.1.1")
  pettyCashParentCode    String       @default("1.1.2")
  bankParentCode         String       @default("1.1.3")
  // Listas curadas de cuentas a sugerir primero al crear asientos con IA. IDs (no codes) por
  // estabilidad ante renombre. Validadas en OrgSettingsService.update — los codes legacy
  // de arriba NO se validan (decisión consciente, fuera de scope de este PR).
  defaultCashAccountIds  String[]     @default([])
  defaultBankAccountIds  String[]     @default([])
  fleteExpenseAccountCode      String @default("5.1.9")
  polloFaenadoCOGSAccountCode  String @default("5.1.1")
  itExpenseAccountCode         String @default("5.3.3")
  itPayableAccountCode         String @default("2.1.7")
  createdAt              DateTime     @db.Timestamptz(3) @default(now())
  updatedAt              DateTime     @db.Timestamptz(3) @updatedAt
  organization           Organization @relation(fields: [organizationId], references: [id])

  @@map("org_settings")
}

model Dispatch {
  id              String         @id @default(cuid())
  organizationId  String
  dispatchType    DispatchType
  status          DispatchStatus @default(DRAFT)
  sequenceNumber  Int
  referenceNumber Int?
  date            DateTime       @db.Timestamptz(3)
  contactId       String
  periodId        String
  description     String
  farmOrigin      String?
  chickenCount    Int?
  shrinkagePct    Decimal?       @db.Decimal(5, 2) // merma general % (ej: 2.50)
  avgKgPerChicken Decimal?       @db.Decimal(8, 4) // auto: totalNetWeight / chickenCount
  totalGrossKg    Decimal?       @db.Decimal(12, 4) // suma peso bruto
  totalNetKg      Decimal?       @db.Decimal(12, 4) // suma peso neto
  totalShrinkKg   Decimal?       @db.Decimal(12, 4) // suma merma
  totalShortageKg Decimal?       @db.Decimal(12, 4) // suma faltante
  totalRealNetKg  Decimal?       @db.Decimal(12, 4) // suma neto real
  totalAmount     Decimal        @default(0) @db.Decimal(12, 2)
  journalEntryId  String?        @unique
  receivableId    String?        @unique
  notes           String?
  createdById     String
  createdAt       DateTime       @db.Timestamptz(3) @default(now())
  updatedAt       DateTime       @db.Timestamptz(3) @updatedAt
  organization    Organization         @relation(fields: [organizationId], references: [id])
  contact         Contact              @relation(fields: [contactId], references: [id])
  period          FiscalPeriod         @relation(fields: [periodId], references: [id])
  journalEntry    JournalEntry?        @relation(fields: [journalEntryId], references: [id])
  receivable      AccountsReceivable?  @relation(fields: [receivableId], references: [id])
  createdBy       User                 @relation("DispatchCreator", fields: [createdById], references: [id])
  details         DispatchDetail[]

  @@unique([organizationId, dispatchType, sequenceNumber])
  @@index([organizationId, status])
  @@index([organizationId, contactId])
  @@index([organizationId, date])
  @@map("dispatches")
}

model DispatchDetail {
  id             String   @id @default(cuid())
  dispatchId     String
  description    String
  boxes          Int                        // cajas
  grossWeight    Decimal  @db.Decimal(12, 4) // peso bruto
  tare           Decimal  @db.Decimal(12, 4) // tara = cajas × 2 kg
  netWeight      Decimal  @db.Decimal(12, 4) // peso neto = bruto - tara
  unitPrice      Decimal  @db.Decimal(12, 4) // precio por kg
  shrinkage      Decimal? @db.Decimal(12, 4) // BC: merma = netWeight × header shrinkagePct/100
  shortage       Decimal? @db.Decimal(12, 4) // BC: faltante (manual por fila)
  realNetWeight  Decimal? @db.Decimal(12, 4) // BC: neto real = netWeight - merma - faltante
  lineAmount     Decimal  @db.Decimal(12, 2) // ND: netWeight×price, BC: realNetWeight×price
  order          Int      @default(0)
  productTypeId  String?
  detailNote     String?
  dispatch       Dispatch       @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  productType    ProductType?   @relation(fields: [productTypeId], references: [id])

  @@index([dispatchId])
  @@map("dispatch_details")
}

model ProductType {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @db.Timestamptz(3) @default(now())
  updatedAt      DateTime @db.Timestamptz(3) @updatedAt
  organization      Organization     @relation(fields: [organizationId], references: [id])
  dispatchDetails   DispatchDetail[]
  purchaseDetails   PurchaseDetail[]

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
  @@map("product_types")
}

model Payment {
  id                    String        @id @default(cuid())
  organizationId        String
  status                PaymentStatus @default(DRAFT)
  method                PaymentMethod
  date                  DateTime      @db.Timestamptz(3)
  amount                Decimal       @db.Decimal(12, 2)
  description           String
  periodId              String
  contactId             String
  referenceNumber       Int?
  journalEntryId        String?       @unique
  notes                 String?
  accountCode           String?
  operationalDocTypeId  String?
  createdById           String
  createdAt             DateTime      @db.Timestamptz(3) @default(now())
  updatedAt             DateTime      @db.Timestamptz(3) @updatedAt
  organization          Organization         @relation(fields: [organizationId], references: [id])
  contact               Contact              @relation(fields: [contactId], references: [id])
  period                FiscalPeriod         @relation(fields: [periodId], references: [id])
  journalEntry          JournalEntry?        @relation(fields: [journalEntryId], references: [id])
  createdBy             User                 @relation("PaymentCreator", fields: [createdById], references: [id])
  operationalDocType    OperationalDocType?  @relation(fields: [operationalDocTypeId], references: [id])
  allocations           PaymentAllocation[]

  @@index([organizationId, status])
  @@index([organizationId, contactId])
  @@index([organizationId, date])
  @@map("payments")
}

model OperationalDocType {
  id             String                  @id @default(cuid())
  organizationId String
  code           String
  name           String
  direction      OperationalDocDirection
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @db.Timestamptz(3) @default(now())
  updatedAt      DateTime                @db.Timestamptz(3) @updatedAt

  organization   Organization            @relation(fields: [organizationId], references: [id])
  payments       Payment[]

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
  @@map("operational_doc_types")
}

model Purchase {
  id              String         @id @default(cuid())
  organizationId  String
  purchaseType    PurchaseType
  status          PurchaseStatus @default(DRAFT)
  sequenceNumber  Int
  date            DateTime       @db.Timestamptz(3)
  contactId       String
  periodId        String
  description     String
  referenceNumber Int?
  notes           String?
  totalAmount     Decimal        @default(0) @db.Decimal(12, 2)
  // FLETE only
  ruta            String?
  // POLLO_FAENADO only
  farmOrigin      String?
  chickenCount    Int?
  shrinkagePct    Decimal?       @db.Decimal(5, 2)
  totalGrossKg    Decimal?       @db.Decimal(12, 4)
  totalNetKg      Decimal?       @db.Decimal(12, 4)
  totalShrinkKg   Decimal?       @db.Decimal(12, 4)
  totalShortageKg Decimal?       @db.Decimal(12, 4)
  totalRealNetKg  Decimal?       @db.Decimal(12, 4)
  journalEntryId  String?        @unique
  payableId       String?        @unique
  createdById     String
  createdAt       DateTime       @db.Timestamptz(3) @default(now())
  updatedAt       DateTime       @db.Timestamptz(3) @updatedAt
  organization    Organization         @relation(fields: [organizationId], references: [id])
  contact         Contact              @relation(fields: [contactId], references: [id])
  period          FiscalPeriod         @relation(fields: [periodId], references: [id])
  journalEntry    JournalEntry?        @relation(fields: [journalEntryId], references: [id])
  payable         AccountsPayable?     @relation(fields: [payableId], references: [id])
  createdBy       User                 @relation("PurchaseCreator", fields: [createdById], references: [id])
  details         PurchaseDetail[]
  ivaPurchaseBook IvaPurchaseBook?

  @@unique([organizationId, purchaseType, sequenceNumber])
  @@index([organizationId, status])
  @@index([organizationId, contactId])
  @@index([organizationId, date])
  @@map("purchases")
}

model PurchaseDetail {
  id               String   @id @default(cuid())
  purchaseId       String
  description      String
  lineAmount       Decimal  @db.Decimal(12, 2)
  order            Int      @default(0)
  // FLETE columns
  fecha            DateTime? @db.Timestamptz(3)
  docRef           String?
  chickenQty       Int?
  pricePerChicken  Decimal? @db.Decimal(12, 4)
  // POLLO_FAENADO columns (mirrors DispatchDetail)
  productTypeId    String?
  detailNote       String?
  boxes            Int?
  grossWeight      Decimal? @db.Decimal(12, 4)
  tare             Decimal? @db.Decimal(12, 4)
  netWeight        Decimal? @db.Decimal(12, 4)
  unitPrice        Decimal? @db.Decimal(12, 4)
  shrinkage        Decimal? @db.Decimal(12, 4)
  shortage         Decimal? @db.Decimal(12, 4)
  realNetWeight    Decimal? @db.Decimal(12, 4)
  // COMPRA_GENERAL / SERVICIO columns
  quantity         Decimal? @db.Decimal(12, 4)
  expenseAccountId String?
  purchase         Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productType      ProductType?   @relation(fields: [productTypeId], references: [id])
  expenseAccount   Account?       @relation(fields: [expenseAccountId], references: [id])

  @@index([purchaseId])
  @@map("purchase_details")
}

model PaymentAllocation {
  id            String              @id @default(cuid())
  paymentId     String
  receivableId  String?
  payableId     String?
  amount        Decimal             @db.Decimal(12, 2)
  payment       Payment             @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  receivable    AccountsReceivable? @relation(fields: [receivableId], references: [id])
  payable       AccountsPayable?    @relation(fields: [payableId], references: [id])

  @@index([paymentId])
  @@index([receivableId])
  @@index([payableId])
  @@map("payment_allocations")
}


model Sale {
  id              String       @id @default(cuid())
  organizationId  String
  status          SaleStatus   @default(DRAFT)
  sequenceNumber  Int
  date            DateTime     @db.Timestamptz(3)
  contactId       String
  periodId        String
  description     String
  referenceNumber Int?
  notes           String?
  totalAmount     Decimal      @default(0) @db.Decimal(12, 2)
  journalEntryId  String?      @unique
  receivableId    String?      @unique
  createdById     String
  createdAt       DateTime     @db.Timestamptz(3) @default(now())
  updatedAt       DateTime     @db.Timestamptz(3) @updatedAt
  organization    Organization         @relation(fields: [organizationId], references: [id])
  contact         Contact              @relation(fields: [contactId], references: [id])
  period          FiscalPeriod         @relation(fields: [periodId], references: [id])
  journalEntry    JournalEntry?        @relation(fields: [journalEntryId], references: [id])
  receivable      AccountsReceivable?  @relation(fields: [receivableId], references: [id])
  createdBy       User                 @relation("SaleCreator", fields: [createdById], references: [id])
  details         SaleDetail[]
  ivaSalesBook    IvaSalesBook?

  @@unique([organizationId, sequenceNumber])
  @@index([organizationId, status])
  @@index([organizationId, contactId])
  @@index([organizationId, date])
  @@map("sales")
}

model SaleDetail {
  id              String   @id @default(cuid())
  saleId          String
  description     String
  lineAmount      Decimal  @db.Decimal(12, 2)
  order           Int      @default(0)
  quantity        Decimal? @db.Decimal(12, 4)
  unitPrice       Decimal? @db.Decimal(12, 4)
  incomeAccountId String
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  incomeAccount   Account  @relation(fields: [incomeAccountId], references: [id])

  @@index([saleId])
  @@map("sale_details")
}

model AuditLog {
  id              String   @id @default(cuid())
  organizationId  String
  entityType      String   // tablas: "dispatches", "payments", "journal_entries", "sales", "purchases", "sale_details", "purchase_details", "journal_lines", "fiscal_periods"
  entityId        String
  action          String   // "CREATE" (INSERT), "UPDATE", "DELETE", "STATUS_CHANGE" (UPDATE con cambio de status)
  oldValues       Json?
  newValues       Json?
  changedById     String?
  justification   String?
  correlationId   String?  // Groups all audit rows emitted by a single close/reopen operation
  createdAt       DateTime @db.Timestamptz(3) @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, createdAt])
  @@index([correlationId])
  @@index([organizationId, entityType, createdAt])
  @@index([organizationId, changedById, createdAt])
  @@map("audit_logs")
}

// ── IVA Books ─────────────────────────────────────────────────────────────────

model IvaPurchaseBook {
  id                       String         @id @default(cuid())
  organizationId           String
  fiscalPeriodId           String
  purchaseId               String?        @unique
  fechaFactura             DateTime       @db.Timestamptz(3)
  nitProveedor             String
  razonSocial              String
  numeroFactura            String
  codigoAutorizacion       String
  codigoControl            String         @default("")
  importeTotal             Decimal        @default(0) @db.Decimal(14, 2)
  importeIce               Decimal        @default(0) @db.Decimal(14, 2)
  importeIehd              Decimal        @default(0) @db.Decimal(14, 2)
  importeIpj               Decimal        @default(0) @db.Decimal(14, 2)
  tasas                    Decimal        @default(0) @db.Decimal(14, 2)
  otrosNoSujetos           Decimal        @default(0) @db.Decimal(14, 2)
  exentos                  Decimal        @default(0) @db.Decimal(14, 2)
  tasaCero                 Decimal        @default(0) @db.Decimal(14, 2)
  subtotal                 Decimal        @default(0) @db.Decimal(14, 2)
  dfIva                    Decimal        @default(0) @db.Decimal(14, 2)
  codigoDescuentoAdicional Decimal        @default(0) @db.Decimal(14, 2)
  importeGiftCard          Decimal        @default(0) @db.Decimal(14, 2)
  baseIvaSujetoCf          Decimal        @default(0) @db.Decimal(14, 2)
  dfCfIva                  Decimal        @default(0) @db.Decimal(14, 2)
  tasaIva                  Decimal        @default(0) @db.Decimal(5, 4)
  tipoCompra               Int            @default(1)
  status                   IvaBookStatus  @default(ACTIVE)
  notes                    String?
  createdAt                DateTime       @db.Timestamptz(3) @default(now())
  updatedAt                DateTime       @db.Timestamptz(3) @updatedAt
  organization             Organization   @relation(fields: [organizationId], references: [id])
  fiscalPeriod             FiscalPeriod   @relation(fields: [fiscalPeriodId], references: [id])
  purchase                 Purchase?      @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@unique([organizationId, nitProveedor, numeroFactura, codigoAutorizacion])
  @@index([organizationId, fiscalPeriodId])
  @@map("iva_purchase_books")
}

model IvaSalesBook {
  id                       String              @id @default(cuid())
  organizationId           String
  fiscalPeriodId           String
  saleId                   String?             @unique
  fechaFactura             DateTime            @db.Timestamptz(3)
  nitCliente               String
  razonSocial              String
  numeroFactura            String
  codigoAutorizacion       String
  codigoControl            String              @default("")
  importeTotal             Decimal             @default(0) @db.Decimal(14, 2)
  importeIce               Decimal             @default(0) @db.Decimal(14, 2)
  importeIehd              Decimal             @default(0) @db.Decimal(14, 2)
  importeIpj               Decimal             @default(0) @db.Decimal(14, 2)
  tasas                    Decimal             @default(0) @db.Decimal(14, 2)
  otrosNoSujetos           Decimal             @default(0) @db.Decimal(14, 2)
  exentos                  Decimal             @default(0) @db.Decimal(14, 2)
  tasaCero                 Decimal             @default(0) @db.Decimal(14, 2)
  subtotal                 Decimal             @default(0) @db.Decimal(14, 2)
  dfIva                    Decimal             @default(0) @db.Decimal(14, 2)
  codigoDescuentoAdicional Decimal             @default(0) @db.Decimal(14, 2)
  importeGiftCard          Decimal             @default(0) @db.Decimal(14, 2)
  baseIvaSujetoCf          Decimal             @default(0) @db.Decimal(14, 2)
  dfCfIva                  Decimal             @default(0) @db.Decimal(14, 2)
  tasaIva                  Decimal             @default(0) @db.Decimal(5, 4)
  estadoSIN                IvaSalesEstadoSIN
  status                   IvaBookStatus       @default(ACTIVE)
  notes                    String?
  createdAt                DateTime            @db.Timestamptz(3) @default(now())
  updatedAt                DateTime            @db.Timestamptz(3) @updatedAt
  organization             Organization        @relation(fields: [organizationId], references: [id])
  fiscalPeriod             FiscalPeriod        @relation(fields: [fiscalPeriodId], references: [id])
  sale                     Sale?               @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@unique([organizationId, numeroFactura, codigoAutorizacion])
  @@index([organizationId, fiscalPeriodId])
  @@map("iva_sales_books")
}

// ── Organization Profile & Document Signature Configs ────────────────────────

enum SignatureLabel {
  ELABORADO
  APROBADO
  VISTO_BUENO
  PROPIETARIO
  REVISADO
  REGISTRADO
  CONTABILIZADO
}

enum DocumentPrintType {
  BALANCE_GENERAL
  ESTADO_RESULTADOS
  COMPROBANTE
  DESPACHO
  VENTA
  COMPRA
  COBRO
  PAGO
}

model OrgProfile {
  id             String   @id @default(cuid())
  organizationId String   @unique
  razonSocial    String   @default("")
  nit            String   @default("")
  direccion      String   @default("")
  ciudad         String   @default("")
  telefono           String   @default("")
  representanteLegal String   @default("")
  nroPatronal        String?
  logoUrl        String?
  createdAt      DateTime @db.Timestamptz(3) @default(now())
  updatedAt      DateTime @db.Timestamptz(3) @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@map("org_profile")
}

model DocumentSignatureConfig {
  id              String            @id @default(cuid())
  organizationId  String
  documentType    DocumentPrintType
  labels          SignatureLabel[]
  showReceiverRow Boolean           @default(false)
  createdAt       DateTime          @db.Timestamptz(3) @default(now())
  updatedAt       DateTime          @db.Timestamptz(3) @updatedAt
  organization    Organization      @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, documentType])
  @@index([organizationId])
  @@map("document_signature_config")
}