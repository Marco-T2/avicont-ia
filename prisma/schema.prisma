// prisma/schema.prisma
// Define your database models

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String   @id @default(cuid())
  clerkOrgId  String   @unique
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  members        OrganizationMember[]
  documents      Document[]
  farms          Farm[]
  chickenLots    ChickenLot[]
  expenses       Expense[]
  mortalityLogs  MortalityLog[]
  accounts        Account[]
  journalEntries  JournalEntry[]
  fiscalPeriods   FiscalPeriod[]
  voucherTypes    VoucherTypeCfg[]
  accountBalances AccountBalance[]
  contacts        Contact[]
  receivables     AccountsReceivable[]
  payables        AccountsPayable[]
  settings        OrgSettings?
  dispatches         Dispatch[]
  payments           Payment[]
  productTypes       ProductType[]
  auditLogs          AuditLog[]
  creditConsumptions CreditConsumption[]

  @@map("organizations")
}

model OrganizationMember {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  role           String    @default("member")
  deactivatedAt  DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  farms          Farm[]

  @@unique([organizationId, userId])
  @@index([organizationId, deactivatedAt])
  @@map("organization_members")
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String
  name        String?
  createdAt   DateTime @default(now())
  memberships    OrganizationMember[]
  documents      Document[]
  expenses       Expense[]       @relation("ExpenseCreator")
  mortalityLogs  MortalityLog[]  @relation("MortalityCreator")
  journalEntries JournalEntry[]  @relation("JournalCreator")
  dispatches     Dispatch[]      @relation("DispatchCreator")
  payments       Payment[]       @relation("PaymentCreator")

  @@map("users")
}

model Document {
  id             String        @id @default(cuid())
  name           String
  content        String?
  fileUrl        String?
  fileSize       Int?
  fileType       String?
  aiSummary      String?
  aiKeywords     String[]
  sentiment      String?
  scope          DocumentScope @default(ORGANIZATION)
  organizationId String
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  chunks         DocumentChunk[]

  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, scope])
  @@map("documents")
}

model DocumentChunk {
  id             String        @id @default(cuid())
  documentId     String
  organizationId String
  scope          DocumentScope
  content        String
  chunkIndex     Int
  embedding      Unsupported("vector(768)")
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([organizationId, scope])
  @@map("document_chunks")
}

model ChatMessage {
  id             String   @id @default(cuid())
  sessionId      String
  organizationId String
  userId         String
  role           String
  content        String
  createdAt      DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([organizationId, userId])
  @@map("chat_messages")
}

enum LotStatus {
  ACTIVE
  CLOSED
  SOLD
}

enum ExpenseCategory {
  ALIMENTO
  CHALA
  AGUA
  GARRAFAS
  MANTENIMIENTO
  GALPONERO
  MEDICAMENTOS
  VETERINARIO
  OTROS
}

model Farm {
  id             String   @id @default(cuid())
  name           String
  location       String?
  organizationId String
  memberId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id])
  member         OrganizationMember @relation(fields: [memberId], references: [id])
  lots           ChickenLot[]

  @@index([organizationId])
  @@index([memberId])
  @@map("farms")
}

model ChickenLot {
  id             String    @id @default(cuid())
  name           String
  barnNumber     Int
  initialCount   Int
  startDate      DateTime
  endDate        DateTime?
  status         LotStatus @default(ACTIVE)
  farmId         String
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  farm           Farm         @relation(fields: [farmId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  expenses       Expense[]
  mortalityLogs  MortalityLog[]

  @@index([organizationId])
  @@index([farmId])
  @@map("chicken_lots")
}

model Expense {
  id             String          @id @default(cuid())
  amount         Decimal         @db.Decimal(12, 2)
  category       ExpenseCategory
  description    String?
  date           DateTime
  lotId          String
  organizationId String
  createdById    String
  createdAt      DateTime        @default(now())
  lot            ChickenLot   @relation(fields: [lotId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdBy      User         @relation("ExpenseCreator", fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([lotId])
  @@index([createdById])
  @@map("expenses")
}

model MortalityLog {
  id             String   @id @default(cuid())
  count          Int
  cause          String?
  date           DateTime
  lotId          String
  organizationId String
  createdById    String
  createdAt      DateTime @default(now())
  lot            ChickenLot   @relation(fields: [lotId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdBy      User         @relation("MortalityCreator", fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([lotId])
  @@index([createdById])
  @@map("mortality_logs")
}

enum DocumentScope {
  ORGANIZATION
  ACCOUNTING
  FARM
}

enum AccountType {
  ACTIVO
  PASIVO
  PATRIMONIO
  INGRESO
  GASTO
}

enum AccountNature {
  DEUDORA   // Activos y Gastos: saldo aumenta con Debe
  ACREEDORA // Pasivos, Patrimonio, Ingresos: saldo aumenta con Haber
}

enum FiscalPeriodStatus {
  OPEN
  CLOSED
}

enum VoucherTypeCode {
  CI // Comprobante de Ingreso
  CE // Comprobante de Egreso
  CD // Comprobante de Diario
  CT // Comprobante de Traspaso
  CA // Comprobante de Apertura
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  LOCKED
  VOIDED
}

model Account {
  id              String        @id @default(cuid())
  code            String
  name            String
  type            AccountType
  nature          AccountNature
  parentId        String?
  level           Int
  isDetail        Boolean       @default(false)
  requiresContact Boolean       @default(false)
  description     String?
  isActive        Boolean       @default(true)
  organizationId  String
  parent          Account?      @relation("AccountTree", fields: [parentId], references: [id])
  children        Account[]     @relation("AccountTree")
  organization    Organization  @relation(fields: [organizationId], references: [id])
  journalLines    JournalLine[]
  balances        AccountBalance[]

  @@unique([organizationId, code])
  @@index([parentId])
  @@map("accounts")
}

model JournalEntry {
  id              String             @id @default(cuid())
  number          Int
  referenceNumber Int?               // optional physical document number
  date            DateTime
  description     String
  status          JournalEntryStatus @default(DRAFT)
  periodId        String
  voucherTypeId   String
  contactId       String?
  sourceType      String?
  sourceId        String?
  organizationId  String
  createdById     String
  updatedById     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  organization    Organization       @relation(fields: [organizationId], references: [id])
  period          FiscalPeriod       @relation(fields: [periodId], references: [id])
  voucherType     VoucherTypeCfg     @relation(fields: [voucherTypeId], references: [id])
  createdBy       User               @relation("JournalCreator", fields: [createdById], references: [id])
  contact         Contact?           @relation(fields: [contactId], references: [id])
  lines           JournalLine[]
  receivables     AccountsReceivable[]
  payables        AccountsPayable[]
  dispatch        Dispatch?
  payment         Payment?

  @@unique([organizationId, voucherTypeId, periodId, number])
  @@unique([organizationId, voucherTypeId, referenceNumber])
  @@index([organizationId, periodId])
  @@index([organizationId, status])
  @@index([organizationId, voucherTypeId, referenceNumber])
  @@index([createdById])
  @@map("journal_entries")
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal      @default(0) @db.Decimal(12, 2)
  credit         Decimal      @default(0) @db.Decimal(12, 2)
  description    String?
  contactId      String?
  order          Int          @default(0)
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        Account      @relation(fields: [accountId], references: [id])
  contact        Contact?     @relation(fields: [contactId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_lines")
}

model FiscalPeriod {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  year           Int
  startDate      DateTime
  endDate        DateTime
  status         FiscalPeriodStatus @default(OPEN)
  createdById    String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id])
  journalEntries JournalEntry[]
  balances       AccountBalance[]
  dispatches     Dispatch[]
  payments       Payment[]

  @@unique([organizationId, year])
  @@index([organizationId, status])
  @@map("fiscal_periods")
}

model VoucherTypeCfg {
  id             String          @id @default(cuid())
  organizationId String
  code           VoucherTypeCode
  name           String
  description    String?
  isActive       Boolean         @default(true)
  organization   Organization    @relation(fields: [organizationId], references: [id])
  journalEntries JournalEntry[]

  @@unique([organizationId, code])
  @@map("voucher_types")
}

model AccountBalance {
  id             String       @id @default(cuid())
  organizationId String
  accountId      String
  periodId       String
  debitTotal     Decimal      @default(0) @db.Decimal(12, 2)
  creditTotal    Decimal      @default(0) @db.Decimal(12, 2)
  balance        Decimal      @default(0) @db.Decimal(12, 2)
  organization   Organization @relation(fields: [organizationId], references: [id])
  account        Account      @relation(fields: [accountId], references: [id])
  period         FiscalPeriod @relation(fields: [periodId], references: [id])

  @@unique([accountId, periodId])
  @@index([organizationId, periodId])
  @@map("account_balances")
}

// --- Contacts, Receivables, Payables ---

enum ContactType {
  CLIENTE
  PROVEEDOR
  SOCIO
  TRANSPORTISTA
  OTRO
}

enum ReceivableStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED // kept for PostgreSQL compatibility — application code uses VOIDED
  VOIDED
  OVERDUE
}

enum PayableStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED // kept for PostgreSQL compatibility — application code uses VOIDED
  VOIDED
  OVERDUE
}

enum DispatchType {
  NOTA_DESPACHO
  BOLETA_CERRADA
}

enum DispatchStatus {
  DRAFT
  POSTED
  LOCKED
  VOIDED
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  CHEQUE
  DEPOSITO
}

enum PaymentStatus {
  DRAFT
  POSTED
  LOCKED
  VOIDED
}

model Contact {
  id               String      @id @default(cuid())
  organizationId   String
  type             ContactType
  name             String
  nit              String?
  email            String?
  phone            String?
  address          String?
  paymentTermsDays Int         @default(30)
  creditLimit      Decimal?    @db.Decimal(12, 2)
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  organization     Organization         @relation(fields: [organizationId], references: [id])
  journalEntries   JournalEntry[]
  journalLines     JournalLine[]
  receivables      AccountsReceivable[]
  payables         AccountsPayable[]
  dispatches       Dispatch[]
  payments         Payment[]

  @@index([organizationId, type])
  @@index([organizationId, isActive])
  @@index([organizationId, nit])
  @@map("contacts")
}

model AccountsReceivable {
  id             String           @id @default(cuid())
  organizationId String
  contactId      String
  description    String
  amount         Decimal          @db.Decimal(12, 2)
  paid           Decimal          @default(0) @db.Decimal(12, 2)
  balance        Decimal          @db.Decimal(12, 2)
  dueDate        DateTime
  status         ReceivableStatus @default(PENDING)
  sourceType     String?
  sourceId       String?
  journalEntryId String?
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id])
  contact        Contact       @relation(fields: [contactId], references: [id])
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  dispatch       Dispatch?
  allocations    PaymentAllocation[]

  @@index([organizationId, contactId])
  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@map("accounts_receivable")
}

model AccountsPayable {
  id             String        @id @default(cuid())
  organizationId String
  contactId      String
  description    String
  amount         Decimal       @db.Decimal(12, 2)
  paid           Decimal       @default(0) @db.Decimal(12, 2)
  balance        Decimal       @db.Decimal(12, 2)
  dueDate        DateTime
  status         PayableStatus @default(PENDING)
  sourceType     String?
  sourceId       String?
  journalEntryId String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id])
  contact        Contact       @relation(fields: [contactId], references: [id])
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  allocations    PaymentAllocation[]

  @@index([organizationId, contactId])
  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@map("accounts_payable")
}

// --- OrgSettings, Dispatch, Payment ---

model OrgSettings {
  id                     String       @id @default(cuid())
  organizationId         String       @unique
  cajaGeneralAccountCode String       @default("1.1.1.1")
  bancoAccountCode       String       @default("1.1.2.1")
  cxcAccountCode         String       @default("1.1.4.1")
  cxpAccountCode         String       @default("2.1.1.1")
  roundingThreshold      Decimal      @default(0.7) @db.Decimal(3, 2)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  organization           Organization @relation(fields: [organizationId], references: [id])

  @@map("org_settings")
}

model Dispatch {
  id              String         @id @default(cuid())
  organizationId  String
  dispatchType    DispatchType
  status          DispatchStatus @default(DRAFT)
  sequenceNumber  Int
  referenceNumber Int?
  date            DateTime
  contactId       String
  periodId        String
  description     String
  farmOrigin      String?
  chickenCount    Int?
  shrinkagePct    Decimal?       @db.Decimal(5, 2) // merma general % (ej: 2.50)
  avgKgPerChicken Decimal?       @db.Decimal(8, 4) // auto: totalNetWeight / chickenCount
  totalGrossKg    Decimal?       @db.Decimal(12, 4) // suma peso bruto
  totalNetKg      Decimal?       @db.Decimal(12, 4) // suma peso neto
  totalShrinkKg   Decimal?       @db.Decimal(12, 4) // suma merma
  totalShortageKg Decimal?       @db.Decimal(12, 4) // suma faltante
  totalRealNetKg  Decimal?       @db.Decimal(12, 4) // suma neto real
  totalAmount     Decimal        @default(0) @db.Decimal(12, 2)
  journalEntryId  String?        @unique
  receivableId    String?        @unique
  notes           String?
  createdById     String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  organization    Organization         @relation(fields: [organizationId], references: [id])
  contact         Contact              @relation(fields: [contactId], references: [id])
  period          FiscalPeriod         @relation(fields: [periodId], references: [id])
  journalEntry    JournalEntry?        @relation(fields: [journalEntryId], references: [id])
  receivable      AccountsReceivable?  @relation(fields: [receivableId], references: [id])
  createdBy       User                 @relation("DispatchCreator", fields: [createdById], references: [id])
  details         DispatchDetail[]

  @@unique([organizationId, dispatchType, sequenceNumber])
  @@index([organizationId, status])
  @@index([organizationId, contactId])
  @@index([organizationId, date])
  @@map("dispatches")
}

model DispatchDetail {
  id             String   @id @default(cuid())
  dispatchId     String
  description    String
  boxes          Int                        // cajas
  grossWeight    Decimal  @db.Decimal(12, 4) // peso bruto
  tare           Decimal  @db.Decimal(12, 4) // tara = cajas × 2 kg
  netWeight      Decimal  @db.Decimal(12, 4) // peso neto = bruto - tara
  unitPrice      Decimal  @db.Decimal(12, 4) // precio por kg
  shrinkage      Decimal? @db.Decimal(12, 4) // BC: merma = netWeight × header shrinkagePct/100
  shortage       Decimal? @db.Decimal(12, 4) // BC: faltante (manual por fila)
  realNetWeight  Decimal? @db.Decimal(12, 4) // BC: neto real = netWeight - merma - faltante
  lineAmount     Decimal  @db.Decimal(12, 2) // ND: netWeight×price, BC: realNetWeight×price
  order          Int      @default(0)
  productTypeId  String?
  detailNote     String?
  dispatch       Dispatch       @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  productType    ProductType?   @relation(fields: [productTypeId], references: [id])

  @@index([dispatchId])
  @@map("dispatch_details")
}

model ProductType {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id])
  dispatchDetails DispatchDetail[]

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
  @@map("product_types")
}

model Payment {
  id              String        @id @default(cuid())
  organizationId  String
  status          PaymentStatus @default(DRAFT)
  method          PaymentMethod
  date            DateTime
  amount          Decimal       @db.Decimal(12, 2)
  description     String
  periodId        String
  contactId       String
  referenceNumber Int?
  journalEntryId  String?       @unique
  notes           String?
  createdById     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  creditApplied   Decimal              @default(0) @db.Decimal(12, 2)
  organization    Organization         @relation(fields: [organizationId], references: [id])
  contact         Contact              @relation(fields: [contactId], references: [id])
  period          FiscalPeriod         @relation(fields: [periodId], references: [id])
  journalEntry    JournalEntry?        @relation(fields: [journalEntryId], references: [id])
  createdBy       User                 @relation("PaymentCreator", fields: [createdById], references: [id])
  allocations     PaymentAllocation[]
  creditConsumptions CreditConsumption[] @relation("CreditConsumer")
  creditSources      CreditConsumption[] @relation("CreditSource")

  @@index([organizationId, status])
  @@index([organizationId, contactId])
  @@index([organizationId, date])
  @@map("payments")
}

model PaymentAllocation {
  id            String              @id @default(cuid())
  paymentId     String
  receivableId  String?
  payableId     String?
  amount        Decimal             @db.Decimal(12, 2)
  payment       Payment             @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  receivable    AccountsReceivable? @relation(fields: [receivableId], references: [id])
  payable       AccountsPayable?    @relation(fields: [payableId], references: [id])

  @@index([paymentId])
  @@index([receivableId])
  @@index([payableId])
  @@map("payment_allocations")
}

model CreditConsumption {
  id                String   @id @default(cuid())
  organizationId    String
  consumerPaymentId String
  sourcePaymentId   String
  amount            Decimal  @db.Decimal(12, 2)
  createdAt         DateTime @default(now())
  organization      Organization @relation(fields: [organizationId], references: [id])
  consumerPayment   Payment      @relation("CreditConsumer", fields: [consumerPaymentId], references: [id])
  sourcePayment     Payment      @relation("CreditSource", fields: [sourcePaymentId], references: [id])

  @@index([consumerPaymentId])
  @@index([sourcePaymentId])
  @@index([organizationId])
  @@map("credit_consumptions")
}

model AuditLog {
  id              String   @id @default(cuid())
  organizationId  String
  entityType      String   // "dispatch", "payment", "journal_entry"
  entityId        String
  action          String   // "CREATE", "UPDATE", "DELETE", "STATUS_CHANGE"
  oldValues       Json?
  newValues       Json?
  changedById     String?
  justification   String?
  createdAt       DateTime @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, createdAt])
  @@map("audit_logs")
}